repo_path: "."
output_dir: "./docs"
artifacts_dir: "./artifacts"

llm:
  base_url: "https://open.bigmodel.cn/api/paas/v4"
  api_key_env: "OPENAI_API_KEY"
  planner_model: "glm-4.7-flashx"
  preprocessor_model: "glm-4.7-flashx"
  agent_model: "glm-4.7-flashx"
  max_tokens: 200000
  temperature: 0.2
  timeout_seconds: 120

analysis:
  languages: ["go", "python", "typescript", "rust", "java"]
  exclude_patterns:
    - "*_test.go"
    - "vendor/**"
    - "node_modules/**"
    - "**/*.pb.go"
  shared_module_threshold: 3

agent:
  concurrency: 4
  skeleton_max_tokens: 3000

cache:
  enabled: true
  dir: "./artifacts/cache"

site:
  title: ""
  repo_url: ""
  logo: ""
